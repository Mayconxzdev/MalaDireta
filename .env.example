# Copy to .env and replace every CHANGE_ME value before local use.
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_WITH_A_LONG_RANDOM_VALUE
N8N_ENCRYPTION_KEY=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# SMTP is configured in the encrypted n8n credential store, not here.
